# --- Public (safe to expose to the browser) ---

# Sepolia RPC endpoint (Infura / Alchemy / your own node)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# OPTIONAL override: the SDK ships the official Sepolia registry address
# itself (DefaultRegistryAddresses from "@zama-fhe/sdk") — only set this if
# you need to point at a different/self-deployed registry for local testing.
# NEXT_PUBLIC_REGISTRY_ADDRESS=0x...

# WalletConnect project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# --- Server-only (never exposed to the browser) ---

# Zama's hosted relayer endpoint for Sepolia. Kept server-side and proxied
# via app/api/relayer/[chainId]/route.ts so no key/URL leaks to client JS.
ZAMA_RELAYER_URL=https://relayer.testnet.zama.org/v2